{
  "permissions": {
    "allow": [
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(docker-compose:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(echo:*)",
      "Bash(xargs:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(psql:*)",
      "Bash(test:*)",
      "Bash(curl:*)",
      "Bash(sha256sum:*)",
      "Bash(./scripts/*)",
      "Bash(*.sh)",
      "Bash(bash:*)",
      "Bash(for:*)",
      "Bash(do:*)",
      "Bash(done:*)",
      "Bash(while:*)"
    ],

    "deny": [
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(yarn add:*)",
      "Bash(yarn remove:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm remove:*)",
      "Bash(rm -rf /*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)"
    ],

    "ask": [
      "Bash(npm publish:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(docker system prune:*)",
      "Bash(rm -rf:*)"
    ]
  }
}
